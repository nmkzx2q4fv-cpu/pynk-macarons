# Lang-Caching für Assets. Sicher, weil JS/CSS per ?v=-Token cache-gebustet werden
# und Bilder/Fonts sich praktisch nie ändern. HTML bleibt bewusst ungecacht (Default),
# damit Besucher immer die aktuellen ?v=-Referenzen bekommen.

/img/*
  Cache-Control: public, max-age=31536000, immutable
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
/js/*
  Cache-Control: public, max-age=31536000, immutable
/styles/*
  Cache-Control: public, max-age=31536000, immutable
